#!/bin/sh
# XDG_CURRENT_DESKTOP=GNOME is required for 1Password's browser integration under Sway.
# Wait for waybar's StatusNotifierWatcher before launching: 1Password registers its
# tray icon early in startup, and if the watcher isn't ready the icon is silently dropped.
until busctl --user status org.kde.StatusNotifierWatcher >/dev/null 2>&1; do
    sleep 1
done
exec env XDG_CURRENT_DESKTOP=GNOME 1password --silent
