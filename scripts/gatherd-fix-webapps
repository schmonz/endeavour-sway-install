#!/bin/bash
# Watches for webapp-manager desktop entries:
# - Fixes non-spec-compliant quoting (--app="url" → --app=url) so strict launchers like fuzzel accept them.
# - Seeds default zoom level into each webapp's ice profile.

seed_zoom() {
    local userdata
    userdata=$(sed -n '/^Exec=/s/.*--user-data-dir=\([^ ]*\).*/\1/p' "$1")
    [ -n "$userdata" ] || return
    mkdir -p "$userdata/Default"
    python3 - "$userdata/Default/Preferences" <<'PYEOF'
import json, math, os, sys
zoom = math.log(1.25) / math.log(1.2)
path = sys.argv[1]
try:
    with open(path) as f:
        d = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
d.setdefault('partition', {}).setdefault('default_zoom_level', {})['x'] = zoom
with open(path, 'w') as f:
    json.dump(d, f)
os.chmod(path, 0o600)
PYEOF
}

fix_webapp() {
    sed -i 's/--app="\([^"]*\)"/--app=\1/g' "$1"
    seed_zoom "$1"
}

# Apply to all existing webapps at startup
for f in "$HOME/.local/share/applications/WebApp-"*.desktop; do
    [ -f "$f" ] && fix_webapp "$f"
done

# Watch for new ones
inotifywait -q -m -e close_write,moved_to \
    --format '%f' \
    "$HOME/.local/share/applications/" |
while IFS= read -r filename; do
    case "$filename" in
        WebApp-*.desktop)
            fix_webapp "$HOME/.local/share/applications/$filename"
            ;;
    esac
done
